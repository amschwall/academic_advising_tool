{
  "name": "advising-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "next build && PROD=1 playwright test",
    "scrape": "tsx scripts/scrape-courses.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.10.0",
    "@supabase/supabase-js": "^2.43.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^29.7.0",
    "node-html-parser": "^7.1.0",
    "pg": "^8.11.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "projects": [
      {
        "displayName": "node",
        "preset": "ts-jest",
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        },
        "setupFiles": [
          "<rootDir>/tests/setup.ts"
        ],
        "testMatch": [
          "<rootDir>/tests/**/*.test.ts"
        ]
      },
      {
        "displayName": "jsdom",
        "preset": "ts-jest",
        "testEnvironment": "jsdom",
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        },
        "setupFiles": [
          "<rootDir>/tests/setup.ts"
        ],
        "transform": {
          "^.+\\.[jt]sx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "jsx": "react-jsx"
              }
            }
          ]
        },
        "testMatch": [
          "<rootDir>/tests/**/*.test.tsx"
        ]
      }
    ]
  }
}
